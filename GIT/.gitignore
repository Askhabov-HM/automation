# =========================================================
# Base .gitignore for Full Stack JS/TS Projects
# Stack: Node.js, Express, React, Next.js, Vite, PostgreSQL,
# Docker, Docker Compose, Python helpers, VS Code, Windows
# =========================================================


# ---------------------------------------------------------
# OS: Windows
# ---------------------------------------------------------

Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ---------------------------------------------------------
# Editors / IDE
# ---------------------------------------------------------

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json


# ---------------------------------------------------------
# Environment variables / secrets
# ---------------------------------------------------------

.env
.env.*
!.env.example
!.env.template
!.env.sample

*.pem
*.key
*.crt
*.p12
*.pfx

secrets.*
secret.*
credentials.*
config.local.*
*.local

terraform.tfstate
terraform.tfstate.*
*.tfvars


# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------

logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*


# ---------------------------------------------------------
# Node.js / JavaScript / TypeScript
# ---------------------------------------------------------

node_modules/

# Package manager caches
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# TypeScript
*.tsbuildinfo

# ESLint / Prettier / tooling caches
.eslintcache
.cache/


# ---------------------------------------------------------
# React / Vite
# ---------------------------------------------------------

dist/
dist-ssr/
.vite/
vite.config.*.timestamp-*


# ---------------------------------------------------------
# Next.js
# ---------------------------------------------------------

.next/
out/
.vercel/


# ---------------------------------------------------------
# Build output
# ---------------------------------------------------------

build/
coverage/
.nyc_output/


# ---------------------------------------------------------
# Testing
# ---------------------------------------------------------

test-results/
playwright-report/
playwright/.cache/


# ---------------------------------------------------------
# Python helper scripts / tools
# ---------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

*.egg-info/
.eggs/


# ---------------------------------------------------------
# PostgreSQL / local database files / dumps
# ---------------------------------------------------------

*.db
*.sqlite
*.sqlite3
*.dump
*.sql.gz
*.backup
postgres-data/
pgdata/


# ---------------------------------------------------------
# Docker / Docker Compose local files
# ---------------------------------------------------------

.docker/

docker-compose.override.yml
docker-compose.local.yml

# Keep main Docker files tracked:
# Dockerfile
# docker-compose.yml
# docker-compose.prod.yml


# ---------------------------------------------------------
# Temporary files
# ---------------------------------------------------------

tmp/
temp/
*.tmp
*.temp


# ---------------------------------------------------------
# Uploads / generated local files
# ---------------------------------------------------------

uploads/
storage/
public/uploads/


# ---------------------------------------------------------
# Do NOT ignore by default
# ---------------------------------------------------------

# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# Dockerfile
# docker-compose.yml
# .env.example
# README.md
# docs/
# migrations/
