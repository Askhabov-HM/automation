# Docker
DOCKER_CMD=docker
DOCKER_DESKTOP_EXE=C:\Program Files\Docker\Docker\Docker Desktop.exe
COMPOSE_PROJECT_NAME=postgres-workspace

# Compose services / containers
POSTGRES_SERVICE=postgres
PGADMIN_SERVICE=pgadmin
POSTGRES_CONTAINER_NAME=postgres-workspace-db
PGADMIN_CONTAINER_NAME=postgres-workspace-pgadmin

# PostgreSQL
POSTGRES_DB=demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=CHANGE_ME_PGADMIN_EMAIL
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
PGADMIN_PORT=5050
PGADMIN_URL=http://127.0.0.1:5050/browser/

# Timeouts
DOCKER_READY_TIMEOUT=180
POSTGRES_READY_TIMEOUT=90
PGADMIN_READY_TIMEOUT=60
POLL_INTERVAL=2
